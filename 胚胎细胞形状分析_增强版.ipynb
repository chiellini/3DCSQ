    "## 3. 3D 形状描述符分析\n",
    "\n",
    "基于 **Nature Communications Biology** 文章 (EmbSAM, 2026) 中定义的 3D 形状描述符 [1]，计算以下形状特征：\n",
    "\n",
    "1. **General Sphericity**（广义球度）- 描述细胞与完美球体的相似性\n",
    "2. **Hayakawa Roundness**（Hayakawa 圆度）- 评估表面边缘和角的锐度\n",
    "3. **Spreading Index**（铺展指数）- 反映细胞形状的铺展程度\n",
    "4. **Diameter**（直径）- 用于细胞分裂分析\n",
    "\n",
    "**参考文献**：\n",
    "> Guan, G. et al. EmbSAM: cell boundary localization and Segment Anything Model for fast images of developing embryos. *Commun Biol* **9**, 8 (2026). https://doi.org/10.1038/s42003-025-09220-3"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def calculate_general_sphericity(volume, surface):\n",
    "    \"\"\"\n",
    "    计算广义球度 (General Sphericity)\n",
    "    \n",
    "    定义：与细胞体积相同的完美球体的表面积与细胞表面积的比值\n",
    "    公式：Ψ = (36πV²)^(1/3) / S\n",
    "    \n",
    "    参数:\n",
    "        volume: 细胞体积\n",
    "        surface: 细胞表面积\n",
    "    \n",
    "    返回:\n",
    "        球度值 (0-1 之间，1 表示完美球体)\n",
    "    \"\"\"\n",
    "    if surface == 0:\n",
    "        return 0\n",
    "    sphericity = np.cbrt(36 * np.pi * volume**2) / surface\n",
    "    return sphericity\n",
    "\n",
    "\n",
    "def calculate_hayakawa_roundness(volume, surface, points):\n",
    "    \"\"\"\n",
    "    计算 Hayakawa 圆度 (Hayakawa Roundness)\n",
    "    \n",
    "    定义：评估细胞表面边缘和角的锐度，以及凸凹程度\n",
    "    公式：R = V / (S * (abc)^(1/3))\n",
    "    其中 a, b, c 是定向包围盒 (OBB) 的长、中、短轴长度\n",
    "    \n",
    "    参数:\n",
    "        volume: 细胞体积\n",
    "        surface: 细胞表面积\n",
    "        points: 细胞表面点云 (N×3 数组)\n",
    "    \n",
    "    返回:\n",
    "        圆度值\n",
    "    \"\"\"\n",
    "    if len(points) < 4 or surface == 0:\n",
    "        return 0\n",
    "    \n",
    "    try:\n",
    "        # 使用 PCA 计算定向包围盒 (OBB) 的轴\n",
    "        pca = PCA(n_components=3)\n",
    "        pca.fit(points)\n",
    "        \n",
    "        # 获取三个主轴的标准差作为轴长估计\n",
    "        axis_lengths = np.sqrt(pca.explained_variance_) * 2 * 2.355  # 约 95% 的范围\n",
    "        a, b, c = np.sort(axis_lengths)[::-1]  # 按降序排列\n",
    "        \n",
    "        if a * b * c == 0:\n",
    "            return 0\n",
    "        \n",
    "        roundness = volume / (surface * np.cbrt(a * b * c))\n",
    "        return roundness\n",
    "    except Exception as e:\n",
    "        print(f\"计算 Hayakawa 圆度时出错：{e}\")\n",
    "        return 0\n",
    "\n",
    "\n",
    "def calculate_spreading_index(points):\n",
    "    \"\"\"\n",
    "    计算铺展指数 (Spreading Index)\n",
    "    \n",
    "    定义：反映细胞凸包与完美球体的相似程度，即细胞形状的铺展程度\n",
    "    公式：SI = (36πV_convex²)^(1/3) / S_convex\n",
    "    其中 V_convex 和 S_convex 是细胞凸包的体积和表面积\n",
    "    \n",
    "    参数:\n",
    "        points: 细胞表面点云 (N×3 数组)\n",
    "    \n",
    "    返回:\n",
    "        铺展指数值 (0-1 之间)\n",
    "    \"\"\"\n",
    "    if len(points) < 4:\n",
    "        return 0\n",
    "    \n",
    "    try:\n",
    "        # 计算凸包\n",
    "        hull = ConvexHull(points)\n",
    "        \n",
    "        # 凸包体积和表面积\n",
    "        convex_volume = hull.volume\n",
    "        convex_area = hull.area\n",
    "        \n",
    "        if convex_area == 0:\n",
    "            return 0\n",
    "        \n",
    "        spreading_index = np.cbrt(36 * np.pi * convex_volume**2) / convex_area\n",
    "        return spreading_index\n",
    "    except Exception as e:\n",
    "        print(f\"计算铺展指数时出错：{e}\")\n",
    "        return 0\n",
    "\n",
    "\n",
    "def calculate_diameter(points, nucleus1=None, nucleus2=None):\n",
    "    \"\"\"\n",
    "    计算细胞直径（用于细胞分裂分析）\n",
    "    \n",
    "    在细胞分裂期间，基于两个子细胞核的位置计算收缩环直径\n",
    "    如果没有细胞核信息，则计算点云的最大直径\n",
    "    \n",
    "    参数:\n",
    "        points: 细胞表面点云 (N×3 数组)\n",
    "        nucleus1: 第一个子细胞核位置 (可选)\n",
    "        nucleus2: 第二个子细胞核位置 (可选)\n",
    "    \n",
    "    返回:\n",
    "        直径值 (μm)\n",
    "    \"\"\"\n",
    "    if nucleus1 is not None and nucleus2 is not None:\n",
    "        # 如果有两个细胞核，计算基于收缩环的直径\n",
    "        normal_vector = np.array(nucleus2) - np.array(nucleus1)\n",
    "        A, B, C = normal_vector\n",
    "        \n",
    "        # 找到最小表面积的圆柱体\n",
    "        D_optimal = None\n",
    "        min_surface = float('inf')\n",
    "        \n",
    "        for D in np.linspace(-100, 100, 100):\n",
    "            distances = np.abs(A * points[:, 0] + B * points[:, 1] + C * points[:, 2] + D) / np.sqrt(A**2 + B**2 + C**2)\n",
    "            cylinder_points = points[distances < 0.5]\n",
    "            \n",
    "            if len(cylinder_points) > 3:\n",
    "                try:\n",
    "                    cylinder_hull = ConvexHull(cylinder_points)\n",
    "                    if cylinder_hull.area < min_surface:\n",
    "                        min_surface = cylinder_hull.area\n",
    "                        D_optimal = D\n",
    "                except:\n",
    "                    pass\n",
    "        \n",
    "        if D_optimal is not None and min_surface < float('inf'):\n",
    "            diameter = 0.18 * (np.sqrt(1 + 2 * min_surface / np.pi) - 1)\n",
    "            return diameter\n",
    "    \n",
    "    # 如果没有细胞核信息，计算最大直径\n",
    "    from scipy.spatial.distance import pdist\n",
    "    if len(points) > 1:\n",
    "        max_dist = np.max(pdist(points))\n",
    "        return max_dist * 0.18  # 假设体素大小为 0.18μm\n",
    "    \n",
    "    return 0\n",
    "\n",
    "\n",
    "print(\"✓ 形状描述符函数定义完成\")"
   ]
  },
