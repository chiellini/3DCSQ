    "        'Volume': [volume_dict[l] for l in current_cell_labels],\n",
    "        'Surface': [surface_dict[l] for l in current_cell_labels]\n",
    "    })\n",
    "    \n",
    "    # 计算归一化系数\n",
    "    stats_df['Norm_Coeff'] = (stats_df['Volume'] / 10000) ** (1/3)\n",
