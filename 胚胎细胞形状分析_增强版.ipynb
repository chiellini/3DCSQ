   "source": [
    "if 'current_img_data' in locals():\n",
    "    # 计算所有细胞的体积和表面积\n",
    "    from collections import Counter\n",
    "    \n",
    "    volume_dict = {}\n",
    "    surface_dict = {}\n",
    "    \n",
    "    print(f\"正在计算 {len(current_cell_labels)} 个细胞的体积和表面积...\")\n",
    "    \n",
    "    for cell_label in current_cell_labels:\n",
    "        # 体积：体素计数\n",
    "        volume = np.sum(current_img_data == cell_label)\n",
    "        volume_dict[cell_label] = volume\n",
    "        \n",
    "        # 表面积：使用形态学操作\n",
    "        cell_mask = (current_img_data == cell_label)\n",
    "        dilated = ndimage.binary_dilation(cell_mask)\n",
    "        surface = np.sum(np.logical_xor(dilated, cell_mask))\n",
    "        surface_dict[cell_label] = surface\n",
    "    \n",
    "    # 创建统计 DataFrame\n",
    "    stats_df = pd.DataFrame({\n",
    "        'Cell_Label': current_cell_labels,\n",
